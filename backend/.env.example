# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
# Local:  mongodb://localhost:27017/forkfleet
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/forkfleet
MONGO_URI=mongodb://localhost:27017/forkfleet

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Client (CORS) ────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Promo Codes (comma-separated) ───────────────────
PROMO_CODES=FIRSTBITE:100:free_delivery,SAVE20:20:percent,FLAT5:5:flat
